/**
 * Cloudflare Pages Configuration
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "edge-crm",
  "compatibility_date": "2024-04-03",
  "pages_build_output_dir": "dist",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "crm_db",
      "database_id": "YOUR_D1_DATABASE_ID"
    }
  ],
  "observability": {
    "enabled": true
  }
}
